{
  "name": "agent-swarm-market",
  "version": "0.0.1",
  "private": true,
  "description": "Decentralized micro-task marketplace where AI agents transact in USDC on Arc via Circle Nanopayments.",
  "type": "module",
  "scripts": {
    "gen-entity-secret": "tsx scripts/generate-entity-secret.ts",
    "create-wallets": "tsx scripts/create-wallets.ts",
    "send-nanopayment": "tsx scripts/send-nanopayment.ts",
    "deploy-taskmarket": "tsx scripts/deploy-taskmarket.ts",
    "taskmarket-lifecycle": "tsx scripts/taskmarket-lifecycle.ts",
    "seed-tasks": "tsx scripts/seed-tasks.ts",
    "run-agents": "tsx scripts/run-agents.ts",
    "run-coordinator": "tsx scripts/run-coordinator.ts",
    "dashboard": "tsx server/dashboard/server.ts",
    "start": "tsx server/dashboard/server.ts",
