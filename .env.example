# --- Circle Developer Console ---
# Get these from https://developers.circle.com after creating a developer-controlled wallets project
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CIRCLE_ENTITY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Blockchain — Circle uses its own identifier for Arc testnet
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# Wallet set that groups all agent wallets (created once on first run)
CIRCLE_WALLET_SET_ID=

# Number of specialist agent wallets to create
SPECIALIST_COUNT=8

# LLM provider for agent task execution and result grading
# Options: mistral (default) | claude
LLM_PROVIDER=mistral

# Mistral (default provider)
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_MODEL=mistral-small-latest

# Claude (set LLM_PROVIDER=claude to use)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Arc Testnet RPC (for read-only contract queries)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Specialist agent tuning
AGENT_POLL_MS=1500
AGENT_GAS_FLOOR_USDC=0.1
AGENT_STARTUP_LOOKBACK_TASKS=25

# Auto-approver behavior in scripts/run-agents.ts
# false (default): grade/pay only tasks posted after the current run starts
# true: also re-grade historical completed tasks from prior runs
AUTO_APPROVER_INCLUDE_HISTORY=false
